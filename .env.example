# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ndis_directory"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-key"
GOOGLE_MAPS_API_KEY="your-server-side-google-maps-key"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PLUS="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="notifications@yourdomain.com.au"

# SMS (Twilio)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+61..."

# File Storage (S3/R2)
S3_BUCKET="ndis-directory-uploads"
S3_REGION="ap-southeast-2"
S3_ACCESS_KEY_ID="..."
S3_SECRET_ACCESS_KEY="..."
S3_ENDPOINT=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
